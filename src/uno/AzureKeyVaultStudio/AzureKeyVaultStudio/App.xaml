<Application
    x:Class="AzureKeyVaultStudio.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:ext="using:AzureKeyVaultStudio.Extensions"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!--  Load WinUI resources  -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!--  Load Uno.UI.Toolkit resources  -->
                <ToolkitResources xmlns="using:Uno.Toolkit.UI" />
                <ResourceDictionary Source="ms-appx:///Assets/CustomCompactStyles.xaml" />
                <!--<win:ResourceDictionary Source="ms-appx:///Microsoft.UI.Xaml/DensityStyles/Compact.xaml" />-->
                <ResourceDictionary Source="ms-appx:///Assets/Styles.xaml" />
                <ResourceDictionary>
                    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
                    <converters:DoubleToVisibilityConverter x:Key="DoubleToVisibilityConverter" GreaterThan="0" />
                    <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
                    <ext:DateTimeFormatConverter x:Key="DateTimeFormatConverter" />
                    <converters:EmptyStringToObjectConverter
                        x:Key="EmptyStringToObjectConverter"
                        EmptyValue="False"
                        NotEmptyValue="True" />
                    <converters:StringFormatConverter x:Key="StringFormatConverter" />
                    <ext:EnumToBoolConverter x:Key="EnumToBoolConverter" />
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Light">
                            <SolidColorBrush x:Key="SystemFillColorAttentionBrush" Color="#e2241a" />
                        </ResourceDictionary>
                        <ResourceDictionary x:Key="Dark">
                            <SolidColorBrush x:Key="SystemFillColorAttentionBrush" Color="#f38064" />
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>

            </ResourceDictionary.MergedDictionaries>
            <!--  Add resources here  -->
        </ResourceDictionary>
    </Application.Resources>

</Application>
