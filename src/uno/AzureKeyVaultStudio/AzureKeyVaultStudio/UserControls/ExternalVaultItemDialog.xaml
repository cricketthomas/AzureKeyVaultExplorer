<ContentDialog
    x:Class="AzureKeyVaultStudio.UserControls.ExternalVaultItemDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AzureKeyVaultStudio.UserControls"
    xmlns:m="using:AzureKeyVaultStudio.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AzureKeyVaultStudio.Presentation.ViewModels"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    Style="{ThemeResource DefaultContentDialogStyle}">

    <StackPanel Spacing="8">
        <TextBlock
            Name="ExternalVaultItemMessage"
            x:Uid="ExternalVaultItemMessage"
            HorizontalAlignment="Center"
            TextWrapping="Wrap" />

        <InfoBar
            x:Name="FailureInfoBar"
            x:Uid="FailureInfoBar"
            IsClosable="False"
            IsOpen="{x:Bind ViewModel.HasErrors, Mode=OneWay}"
            Severity="Error" />

        <ComboBox
            x:Uid="ExternalVaultItemTypeComboBox"
            DisplayMemberPath="Value"
            ItemsSource="{x:Bind ViewModel.ItemTypeOptions, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedItemType, Mode=TwoWay}" />

        <TextBox
            Name="ExternalVaultItemUriTextBox"
            x:Uid="ExternalVaultItemUriTextBox"
            MinWidth="450"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Text="{x:Bind ViewModel.ExternalItemVaultUri, Mode=TwoWay}" />
        <TextBox
            Name="ExternalItemVaultNameTextBox"
            x:Uid="ExternalItemVaultNameTextBox"
            MinWidth="450"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Text="{x:Bind ViewModel.ExternalItemVaultName, Mode=TwoWay}" />
    </StackPanel>
</ContentDialog>
