<UserControl
    x:Class="AzureKeyVaultStudio.UserControls.NewItem"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AzureKeyVaultStudio.UserControls"
    xmlns:localx="AzureKeyVaultStudio.UserControls.NewItem"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:skia="http://uno.ui/skia"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d skia">
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>


        <ScrollViewer Grid.Row="0" Padding="16,0">
            <StackPanel
                x:Name="ContentPanel"
                Orientation="Vertical"
                Spacing="4">
                <TextBlock
                    x:Name="NewItemViewBox"
                    x:Uid="NewItemTextBlock"
                    Margin="2,10,0,10"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />
                <InfoBar
                    x:Name="FailureInfoBar"
                    x:Uid="FailureInfoBar"
                    IsClosable="False"
                    IsOpen="{x:Bind ViewModel.HasErrors, Mode=OneWay}"
                    Severity="Error">
                    <InfoBar.ActionButton>
                        <Button
                            x:Uid="ShowErrorsButton"
                            Command="{x:Bind ViewModel.ShowErrorsCommand}"
                            CommandParameter="{x:Bind XamlRoot}" />
                    </InfoBar.ActionButton>
                </InfoBar>
                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock x:Uid="SecretNameTextBlock" />
                    <Grid ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Uid="NewItemTextbox"
                            Grid.Column="0"
                            Text="{x:Bind ViewModel.SecretName, Mode=TwoWay}" />
                        <FontIcon
                            Name="PART_WarningIcon"
                            Grid.Column="1"
                            FontSize="18"
                            Foreground="Orange"
                            Glyph="&#xE814;"
                            Visibility="{x:Bind ViewModel.SecretNameError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>
                </StackPanel>

                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock x:Uid="VaultLocationTextBlock" />
                    <TextBox IsEnabled="False" Text="{x:Bind ViewModel.VaultUri}" />
                </StackPanel>

                <StackPanel Spacing="8">
                    <StackPanel Orientation="Vertical" Spacing="8">
                        <CheckBox
                            x:Name="SetActivationDateCheckbox"
                            x:Uid="SetActivationDateCheckbox"
                            IsChecked="{x:Bind ViewModel.HasActivationDateChecked, Mode=TwoWay}">
                            <TextBlock x:Uid="SetActivationDateTextBlock" />
                        </CheckBox>
                        <controls:WrapPanel
                            HorizontalSpacing="10"
                            Orientation="Horizontal"
                            VerticalSpacing="10"
                            Visibility="{Binding ElementName=SetActivationDateCheckbox, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}">
                            <DatePicker HorizontalAlignment="Left" SelectedDate="{x:Bind ViewModel.ItemPropertiesModel.NotBefore, Mode=TwoWay}" />
                            <TimePicker Time="{x:Bind ViewModel.NotBeforeTimespan, Mode=TwoWay}" />
                        </controls:WrapPanel>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Spacing="8">
                        <CheckBox
                            x:Name="SetExpirationDateCheckbox"
                            x:Uid="SetExpirationDateCheckbox"
                            IsChecked="{x:Bind ViewModel.HasExpirationDateChecked, Mode=TwoWay}">
                            <TextBlock x:Uid="SetExpirationDateTextBlock" />
                        </CheckBox>
                        <controls:WrapPanel
                            HorizontalSpacing="10"
                            Orientation="Horizontal"
                            VerticalSpacing="10"
                            Visibility="{Binding ElementName=SetExpirationDateCheckbox, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}">
                            <DatePicker HorizontalAlignment="Stretch" SelectedDate="{x:Bind ViewModel.ItemPropertiesModel.ExpiresOn, Mode=TwoWay}" />
                            <TimePicker HorizontalAlignment="Stretch" SelectedTime="{x:Bind ViewModel.ExpiresOnTimespan, Mode=TwoWay}" />
                        </controls:WrapPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock x:Uid="EnabledTextBlock" VerticalAlignment="Center" />
                    <ToggleSwitch
                        x:Uid="EnabledToggleSwitch"
                        VerticalAlignment="Center"
                        IsOn="{x:Bind ViewModel.ItemPropertiesModel.Enabled, Mode=TwoWay}"
                        OffContent="No"
                        OnContent="Yes" />
                </StackPanel>

                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock x:Uid="SecretContentTypeTextBlock" Text="" />
                    <TextBox Text="{x:Bind ViewModel.ItemPropertiesModel.ContentType, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock x:Uid="SecretValueTextBlock" />

                    <Grid ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="SecretValueTextbox"
                            x:Uid="SecretValueTextbox"
                            Height="100"
                            AcceptsReturn="True"
                            Text="{x:Bind ViewModel.SecretValue, Mode=TwoWay}"
                            TextWrapping="Wrap" />
                        <FontIcon
                            Grid.Column="1"
                            FontSize="18"
                            Foreground="Orange"
                            Glyph="&#xE814;"
                            Visibility="{x:Bind ViewModel.SecretValueError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>

                </StackPanel>


                <local:TagsEditor Tag="{x:Bind ViewModel.ItemPropertiesModel.Tags, Mode=TwoWay}" />
            </StackPanel>
        </ScrollViewer>


        <Grid
            Grid.Row="1"
            MinHeight="80"
            Padding="24,0"
            VerticalAlignment="Bottom"
            Background="{ThemeResource SolidBackgroundFillColorSecondaryBrush}"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="CreateNewItemButton"
                x:Uid="NewItemSubmitButton"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                Click="CreateNewItemButton_Click"
                Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" />
                    <TextBlock x:Uid="NewItemSubmitButtonText" />
                </StackPanel>
            </Button>
            <Button
                Grid.Column="1"
                Margin="5,0,0,0"
                HorizontalAlignment="Stretch"
                Command="{x:Bind ViewModel.NewSecretVersionCancelCommand, Mode=OneWay}"
                Style="{ThemeResource DefaultButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE711;" />
                    <TextBlock Text="Cancel" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>

    <VisualStateManager.VisualStateGroups>
        <VisualStateGroup>
            <VisualState x:Name="NarrowState">
                <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="0" />
                </VisualState.StateTriggers>
                <VisualState.Setters>
                    <Setter Target="ContentPanel.Margin" Value="10" />
                    <Setter Target="NewItemViewBox.FontSize" Value="20" />
                </VisualState.Setters>
            </VisualState>
            <VisualState x:Name="WideState">
                <VisualState.StateTriggers>
                    <AdaptiveTrigger MinWindowWidth="720" />
                </VisualState.StateTriggers>
                <VisualState.Setters>
                    <Setter Target="ContentPanel.Margin" Value="50,20" />
                    <Setter Target="NewItemViewBox.FontSize" Value="28" />
                </VisualState.Setters>
            </VisualState>
        </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>
</UserControl>
