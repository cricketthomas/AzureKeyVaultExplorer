<ContentDialog
    x:Class="AzureKeyVaultStudio.UserControls.ExternalVaultDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AzureKeyVaultStudio.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:AzureKeyVaultStudio.Presentation.ViewModels"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    Style="{ThemeResource DefaultContentDialogStyle}">
    <!--<ContentDialog.Resources>
        <vm:ExternalVaultDialogViewModel x:Key="ViewModel" />
    </ContentDialog.Resources>-->
    <StackPanel Spacing="8">
        <TextBlock
            Name="ExternalVaultMessage"
            x:Uid="ExternalVaultMessage"
            HorizontalAlignment="Center"
            TextWrapping="Wrap" />
        <InfoBar
            x:Name="FailureInfoBar"
            x:Uid="FailureInfoBar"
            IsClosable="False"
            IsOpen="{x:Bind ViewModel.HasErrors, Mode=OneWay}"
            Severity="Error" />
        <TextBox
            Name="SubscriptionIdTextBox"
            x:Uid="SubscriptionIdTextBox"
            MinWidth="450"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Text="{x:Bind ViewModel.SubscriptionId, Mode=TwoWay}" />
        <TextBox
            Name="ResourceGroupNameTextBox"
            x:Uid="ResourceGroupNameTextBox"
            MinWidth="450"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Text="{x:Bind ViewModel.ResourceGroupName, Mode=TwoWay}" />
        <TextBox
            Name="VaultNameTextBox"
            x:Uid="VaultNameTextBox"
            MinWidth="450"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Text="{x:Bind ViewModel.KeyVaultName, Mode=TwoWay}" />
    </StackPanel>
</ContentDialog>
