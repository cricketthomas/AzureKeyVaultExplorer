<Page
    x:Class="AzureKeyVaultStudio.Presentation.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:AzureKeyVaultStudio.Presentation"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="using:AzureKeyVaultStudio.UserControls"
    xmlns:uen="using:Uno.Extensions.Navigation.UI"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">


    <Grid>
        <Grid.RowDefinitions>
            <!--<RowDefinition Height="Auto" />-->
            <RowDefinition />
        </Grid.RowDefinitions>
        <!--<uc:OverrideTitlebar Grid.Row="0" />-->

        <ScrollViewer Grid.Row="0">
            <StackPanel
                Margin="50"
                HorizontalAlignment="Left"
                Spacing="16">

                <Viewbox MaxHeight="70" HorizontalAlignment="Left">
                    <TextBlock x:Uid="LoginPageHeaderText" />
                </Viewbox>
                <StackPanel MaxWidth="450" Spacing="16">
                    <TextBlock
                        x:Uid="LoginPageGettingStartedCallSign"
                        FontSize="18"
                        FontWeight="SemiBold" />
                    <TextBlock
                        x:Uid="LoginPageGettingStartedMessage"
                        Opacity="0.8"
                        TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Margin="0,16" Spacing="16">

                    <TextBlock>
                        <Run x:Uid="WelcomeText" />
                        <Run Text="{x:Bind ViewModel.Claims.Email, Mode=OneWay}" />
                    </TextBlock>
                    <Button
                        AutomationProperties.AutomationId="MainPageButton"
                        Command="{x:Bind ViewModel.GoToMainLayoutPageCommand, Mode=OneWay}"
                        Style="{StaticResource AccentButtonStyle}"
                        Visibility="{x:Bind ViewModel.GoToMainLayoutPageCommand.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True}">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Uid="GetStartedButton" />
                                <FontIcon Margin="10,0,0,0" Glyph="&#xE9AC;" />
                            </StackPanel>
                        </Button.Content>
                    </Button>
                    <Button
                        x:Name="LoadingButton"
                        Command="{x:Bind ViewModel.GoToMainLayoutPageCancelCommand, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.GoToMainLayoutPageCommand.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=False}">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <FontIcon Glyph="&#xE711;" />
                            <TextBlock x:Uid="CancelTextBlock" />
                            <ProgressRing
                                Width="8"
                                Height="8"
                                Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                                IsActive="True" />
                        </StackPanel>
                    </Button>
                    <Button AutomationProperties.AutomationId="SettingsPageButton" Command="{x:Bind ViewModel.GoToSettingsViewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Uid="LoginPageSettingsText" />
                            <FontIcon
                                Margin="10,0,0,0"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="16"
                                Glyph="&#xE713;" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
