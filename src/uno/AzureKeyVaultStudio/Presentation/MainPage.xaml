<Page
    x:Class="AzureKeyVaultStudio.Presentation.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:local="using:AzureKeyVaultStudio.Presentation"
    xmlns:macos="http://uno.ui/macos"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:skia="http://uno.ui/not_win"
    xmlns:uc="using:AzureKeyVaultStudio.UserControls"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="macos skia">

    <!--  Background=""  -->
    <Grid>
        <Grid.RowDefinitions>
            <!--<win:RowDefinition Height="32" />
            <skia:RowDefinition Height="0" />-->
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--<uc:OverrideTitlebar
            x:Name="DefaultOverrideTitleBar"
            Grid.Row="0"
            skia:Visibility="Collapsed" />-->

        <SplitView
            x:Name="MainSplitView"
            Grid.Row="0"
            DisplayMode="{x:Bind ViewModel.SplitViewDisplay, Mode=TwoWay}"
            IsPaneOpen="{x:Bind ViewModel.IsPaneOpen, Mode=TwoWay}"
            OpenPaneLength="{x:Bind ViewModel.SplitViewWidth, Mode=TwoWay}"
            PaneBackground="Transparent"
            PanePlacement="{x:Bind ViewModel.PanePlacement, Mode=OneWay}">


            <SplitView.Pane>
                <Grid Margin="0,0,0,0" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
                    <Grid
                        Margin="0,6,0,0"
                        BorderThickness="1,0,1,1"
                        CornerRadius="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <RelativePanel
                            Width="{x:Bind MainSplitView.OpenPaneLength, Mode=OneWay}"
                            BorderBrush="{ThemeResource TabViewBorderBrushCustom}"
                            BorderThickness="0,0,0,1">
                            <TextBlock
                                x:Name="PaneHeader"
                                x:Uid="PaneHeader"
                                Margin="5,5,0,0"
                                FontSize="13"
                                FontWeight="Medium"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel
                                Margin="0,0,10,0"
                                HorizontalAlignment="Left"
                                Orientation="Horizontal"
                                RelativePanel.AlignRightWith="PaneHeader"
                                RelativePanel.AlignRightWithPanel="True">
                                <Button
                                    x:Uid="PaneLocationToggleButton"
                                    Command="{x:Bind ViewModel.TogglePaneLocationCommand}"
                                    Content="{x:Bind ViewModel.FontIconType, Mode=OneWay}"
                                    CornerRadius="{ThemeResource CornerRadiusValue}"
                                    FontFamily="Segoe Fluent Icons"
                                    Style="{StaticResource TransparentButton}" />
                                <ToggleButton
                                    x:Uid="PaneDisplayToggleButton"
                                    Command="{x:Bind ViewModel.ToggleSplitViewDisplayCommand}"
                                    Content="&#xE718;"
                                    FontFamily="Segoe Fluent Icons"
                                    Style="{StaticResource TransparentToggleButton}" />
                                <Button
                                    x:Uid="PaneToggleButton"
                                    Command="{x:Bind ViewModel.ClosePaneCommand}"
                                    Content="&#xE8BB;"
                                    FontFamily="Segoe Fluent Icons"
                                    Style="{StaticResource TransparentButton}" />
                            </StackPanel>
                        </RelativePanel>


                        <Border
                            Grid.Row="1"
                            Margin="4"
                            Background="{ThemeResource ControlAltFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource ControlElevationBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <uc:KeyVaultTree
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                DataContext="{x:Bind KeyVaultTreeViewModel}" />
                        </Border>

                        <Grid Grid.Row="1" Visibility="{x:Bind MainSplitView.IsPaneOpen, Mode=OneWay}">

                            <controls:PropertySizer
                                Grid.Row="1"
                                HorizontalAlignment="Left"
                                Binding="{x:Bind ViewModel.InvertedSplitViewWidth, Mode=TwoWay}"
                                Maximum="700"
                                Minimum="100"
                                Visibility="{x:Bind ViewModel.IsPaneLeft, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True}" />

                            <controls:PropertySizer
                                HorizontalAlignment="Right"
                                Binding="{x:Bind ViewModel.SplitViewWidth, Mode=TwoWay}"
                                Maximum="700"
                                Minimum="100"
                                Visibility="{x:Bind ViewModel.IsPaneLeft, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=False}" />
                        </Grid>

                    </Grid>
                </Grid>

            </SplitView.Pane>

            <SplitView.Content>
                <local:TabsControl x:Name="VaultTabsControl" />
            </SplitView.Content>


        </SplitView>

        <uc:StatusBarControl Grid.Row="1" />
    </Grid>

</Page>
