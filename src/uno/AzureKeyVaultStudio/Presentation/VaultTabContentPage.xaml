<Page
    x:Class="AzureKeyVaultStudio.Presentation.VaultTabContentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:CommunityToolkit.WinUI.UI.Controls.Primitives"
    xmlns:skia="http://uno.ui/not_win"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:ui="using:CommunityToolkit.WinUI"
    NavigationCacheMode="Required"
    mc:Ignorable="skia">


    <Grid Background="{ThemeResource TabViewItemHeaderBackgroundSelected}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Margin="10,5"
            VerticalAlignment="Center"
            Background="{ThemeResource BaseBackgroundBrush}"
            Orientation="Vertical">
            <Grid ColumnSpacing="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <toolkit:Segmented
                    Grid.Column="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    SelectedIndex="{x:Bind ViewModel.SelectedIndex, Mode=TwoWay}"
                    SelectionChanged="Segmented_SelectionChanged"
                    SelectionMode="Single">
                    <toolkit:SegmentedItem x:Uid="SegmentedItemSecret" Icon="{ui:FontIcon Glyph=&#xEC19;}" />
                    <toolkit:SegmentedItem x:Uid="SegmentedItemCertificate" Icon="{ui:FontIcon Glyph=&#xEB95;}" />
                    <toolkit:SegmentedItem x:Uid="SegmentedItemKey" Icon="{ui:FontIcon Glyph=&#xE8D7;}" />
                    <toolkit:SegmentedItem x:Uid="SegmentedItemAll" Icon="{ui:FontIcon Glyph=&#xE8A9;}" />
                </toolkit:Segmented>

                <DropDownButton
                    x:Name="NewItemButton"
                    x:Uid="NewItemButton"
                    Grid.Column="1"
                    MinHeight="30"
                    MaxHeight="30"
                    VerticalAlignment="Center">
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem x:Uid="NewSecretButton" Command="{x:Bind ViewModel.NewSecretCommand, Mode=OneWay}" />
                            <MenuFlyoutItem IsEnabled="False" Text="Key.." />
                            <MenuFlyoutItem IsEnabled="False" Text="Certificate.." />
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>

                <TextBox
                    x:Name="SearchTextBox"
                    x:Uid="VaultPageSearchTextBox"
                    Grid.Column="2"
                    MinHeight="30"
                    MaxHeight="30"
                    AcceptsReturn="False"
                    Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay}"
                    TextChanged="SearchTextBox_TextChanged">
                    <TextBox.KeyboardAccelerators>
                        <KeyboardAccelerator
                            Key="F"
                            Invoked="SearchTextBox_KeyboardAcceleratorInvoked"
                            Modifiers="Control" />
                    </TextBox.KeyboardAccelerators>
                </TextBox>

                <Button
                    Grid.Column="3"
                    MinHeight="30"
                    MaxHeight="30"
                    HorizontalAlignment="Center"
                    Command="{x:Bind ViewModel.RefreshCommand, Mode=OneWay}"
                    ToolTipService.ToolTip="Refresh (F5)">
                    <FontIcon FontSize="14" Glyph="&#xE72C;" />
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="F5" />
                    </Button.KeyboardAccelerators>
                </Button>
            </Grid>
        </StackPanel>

        <Grid Grid.Row="1">
            <StackPanel
                x:Name="LoadingIndicator"
                Width="200"
                Height="200"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                x:Load="{x:Bind ViewModel.FilterAndLoadVaultValueTypeCommand.IsRunning, Mode=OneWay}"
                Orientation="Horizontal"
                Visibility="{x:Bind ViewModel.FilterAndLoadVaultValueTypeCommand.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=False}">
                <Button Command="{x:Bind ViewModel.FilterAndLoadVaultValueTypeCancelCommand, Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <FontIcon Glyph="&#xE711;" />
                        <TextBlock x:Uid="CancelButtonTextBlock" />
                        <ProgressRing
                            Width="8"
                            Height="8"
                            Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                            IsActive="True" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <toolkit:SwitchPresenter TargetType="x:Boolean" Value="{x:Bind ViewModel.HasAuthorizationError, Mode=OneWay}">
                <toolkit:Case IsDefault="True" Value="False">
                    <controls:DataGrid
                        x:Name="VaultContentDataGrid"
                        Margin="5,0,5,10"
                        VerticalAlignment="Stretch"
                        skia:PreviewKeyDown="VaultContentDataGrid_PreviewKeyDown"
                        AlternatingRowBackground="{ThemeResource LayerFillColorDefaultBrush}"
                        AutoGenerateColumns="False"
                        BorderThickness="1"
                        CanUserReorderColumns="True"
                        CanUserResizeColumns="True"
                        CanUserSortColumns="True"
                        CornerRadius="5"
                        DoubleTapped="VaultContentDataGrid_DoubleTapped"
                        FontSize="12"
                        FrozenColumnCount="2"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column"
                        HorizontalGridLinesBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        HorizontalScrollBarVisibility="Auto"
                        IsReadOnly="True"
                        LoadingRow="LoadingRow"
                        LoadingRowGroup="VaultContentDataGrid_LoadingRowGroup"
                        MaxColumnWidth="400"
                        RowDetailsVisibilityMode="Collapsed"
                        SelectedItem="{x:Bind ViewModel.SelectedRow, Mode=TwoWay}"
                        SelectionMode="Single"
                        Sorting="VaultContentDataGrid_Sorting"
                        VerticalScrollBarVisibility="Auto"
                        Visibility="{x:Bind ViewModel.FilterAndLoadVaultValueTypeCommand.IsRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True}">
                        <controls:DataGrid.RowGroupHeaderStyles>
                            <Style TargetType="controls:DataGridRowGroupHeader">
                                <Setter Property="MaxHeight" Value="25" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Height" Value="25" />
                                <Setter Property="MinHeight" Value="25" />
                            </Style>
                        </controls:DataGrid.RowGroupHeaderStyles>
                        <controls:DataGrid.Resources>
                            <ResourceDictionary>
                                <x:Double x:Key="DataGridSortIconMinWidth">0</x:Double>
                                <SolidColorBrush x:Key="DataGridCellFocusVisualPrimaryBrush" Color="Transparent" />
                                <SolidColorBrush x:Key="DataGridCellFocusVisualSecondaryBrush" Color="Transparent" />
                                <ResourceDictionary.ThemeDictionaries>
                                    <ResourceDictionary x:Key="Light">
                                        <Color x:Key="DataGridColumnHeaderBackgroundColor">#eaeaea</Color>
                                        <Color x:Key="DataGridColumnHeaderHoveredBackgroundColor">#4C3A3A3A</Color>
                                        <Color x:Key="DataGridColumnHeaderPressedBackgroundColor">#eeeeee</Color>
                                    </ResourceDictionary>
                                    <ResourceDictionary x:Key="Dark">
                                        <Color x:Key="DataGridColumnHeaderBackgroundColor">#202020</Color>
                                        <Color x:Key="DataGridColumnHeaderHoveredBackgroundColor">#2D2D2D</Color>
                                        <Color x:Key="DataGridColumnHeaderPressedBackgroundColor">#333333</Color>
                                    </ResourceDictionary>
                                </ResourceDictionary.ThemeDictionaries>
                            </ResourceDictionary>
                        </controls:DataGrid.Resources>
                        <controls:DataGrid.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem
                                    x:Name="VaultPageCopyButton"
                                    x:Uid="VaultPageCopyButton"
                                    skia:KeyboardAcceleratorTextOverride="Ctrl+C"
                                    Command="{x:Bind ViewModel.CopyCommand, Mode=OneWay}"
                                    CommandParameter="{x:Bind ViewModel.SelectedRow, Mode=OneWay}"
                                    Icon="Copy">
                                    <MenuFlyoutItem.KeyboardAccelerators>
                                        <KeyboardAccelerator Key="C" Modifiers="Control" />
                                    </MenuFlyoutItem.KeyboardAccelerators>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem
                                    x:Name="VaultPageShowPropertiesButton"
                                    x:Uid="VaultPageShowPropertiesButton"
                                    Command="{x:Bind ViewModel.ShowPropertiesCommand, Mode=OneWay}"
                                    CommandParameter="{x:Bind ViewModel.SelectedRow, Mode=OneWay}"
                                    Icon="ShowResults" />
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem
                                    x:Name="VaultPageOpenInAzureButton"
                                    x:Uid="VaultPageOpenInAzureButton"
                                    Command="{x:Bind ViewModel.OpenInAzureCommand, Mode=OneWay}"
                                    CommandParameter="{x:Bind ViewModel.SelectedRow, Mode=OneWay}">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE8A7;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem
                                    x:Name="VaultPageCopyUriButton"
                                    x:Uid="VaultPageCopyUriButton"
                                    Command="{x:Bind ViewModel.CopyUriCommand, Mode=OneWay}"
                                    CommandParameter="{x:Bind ViewModel.SelectedRow, Mode=OneWay}"
                                    Icon="Link" />
                            </MenuFlyout>
                        </controls:DataGrid.ContextFlyout>
                        <controls:DataGrid.RowStyle>
                            <Style TargetType="controls:DataGridRow">
                                <Setter Property="Height" Value="25" />
                            </Style>
                        </controls:DataGrid.RowStyle>
                        <controls:DataGrid.ColumnHeaderStyle>
                            <Style TargetType="primitives:DataGridColumnHeader">
                                <Setter Property="MaxHeight" Value="25" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter Property="Height" Value="25" />
                                <Setter Property="MinHeight" Value="25" />
                                <Setter Property="SeparatorBrush">
                                    <Setter.Value>
                                        <SolidColorBrush Opacity=".5" Color="{ThemeResource AccentAAFillColorDisabled}" />
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </controls:DataGrid.ColumnHeaderStyle>
                        <controls:DataGrid.CellStyle>
                            <Style TargetType="controls:DataGridCell">
                                <Setter Property="FontSize" Value="14" />
                                <Setter Property="Margin" Value="0,-8,0,0" />
                                <Setter Property="FontWeight" Value="Normal" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="FocusVisualMargin" Value="0" />
                            </Style>
                        </controls:DataGrid.CellStyle>

                        <controls:DataGrid.Columns>
                            <controls:DataGridTextColumn
                                x:Uid="DataGridTextColumnName"
                                Width="200"
                                Binding="{Binding Name}"
                                CanUserSort="True"
                                Tag="Name" />

                            <controls:DataGridTextColumn
                                x:Uid="DataGridTextColumnWhenLastModified"
                                Binding="{Binding WhenLastModified}"
                                CanUserSort="True"
                                Tag="UpdatedOn" />

                            <controls:DataGridTextColumn
                                x:Uid="DataGridTextColumnWhenExpires"
                                Width="150"
                                Binding="{Binding WhenExpires}"
                                CanUserSort="True"
                                Tag="ExpiresOn" />

                            <controls:DataGridTemplateColumn
                                x:Uid="DataGridTextColumnTags"
                                Width="200"
                                CanUserSort="True"
                                Tag="TagValuesString">
                                <controls:DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ItemsRepeater ItemsSource="{Binding TagValues}">
                                            <ItemsRepeater.Layout>
                                                <StackLayout Orientation="Horizontal" Spacing="2" />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="x:String">
                                                    <Border
                                                        Height="20"
                                                        MaxWidth="80"
                                                        Padding="5,2"
                                                        Background="{ThemeResource AccentAcrylicBackgroundFillColorDefaultBrush}"
                                                        CornerRadius="2">
                                                        <TextBlock
                                                            VerticalAlignment="Center"
                                                            FontSize="11"
                                                            IsTextSelectionEnabled="False"
                                                            Text="{x:Bind Mode=OneTime}"
                                                            TextTrimming="CharacterEllipsis" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </DataTemplate>
                                </controls:DataGridTemplateColumn.CellTemplate>
                            </controls:DataGridTemplateColumn>

                            <controls:DataGridTextColumn
                                x:Uid="DataGridTextColumnContentType"
                                Width="200"
                                Binding="{Binding ContentType}"
                                CanUserSort="True"
                                Tag="ContentType" />

                            <controls:DataGridTextColumn
                                x:Uid="DataGridTextColumnUpdated"
                                Width="200"
                                Binding="{Binding UpdatedOn}"
                                CanUserSort="True"
                                Tag="UpdatedOn" />
                        </controls:DataGrid.Columns>


                    </controls:DataGrid>
                </toolkit:Case>

                <toolkit:Case Value="True">

                    <ScrollViewer>
                        <StackPanel
                            Margin="16,8"
                            Padding="16,0"
                            Background="{ThemeResource SubtleFillColorTertiaryBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Orientation="Vertical">
                            <Button
                                Margin="0,10,0,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Command="{x:Bind ViewModel.CloseErrorCommand, Mode=OneWay}"
                                Content="&#xE8BB;"
                                FontFamily="{StaticResource SymbolThemeFontFamily}" />
                            <TextBlock
                                xml:space="preserve"
                                IsTextSelectionEnabled="True"
                                Text="{x:Bind ViewModel.AuthorizationMessage, Mode=OneWay}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>

                </toolkit:Case>
            </toolkit:SwitchPresenter>

        </Grid>

    </Grid>
</Page>

